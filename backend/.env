# Database Configuration
# docker： =db，local：DB_HOST=127.0.0.1
DB_HOST=db
DB_USER=dbeaver
DB_PASSWORD=dbeaver123
DB_NAME=food_ordering
DB_PORT=3306      #  docker： 3306，local：3307
DB_DIALECT=mariadb

# Redis Configuration
#  npm run dev connects to Redis at 127.0.0.1:6380
REDIS_HOST=127.0.0.1
REDIS_PORT=6379   # docker：6079，local：6080

# JWT & Other
JWT_SECRET=food-ordering-system-secret-key-development
JWT_EXPIRES_IN=2h
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:80